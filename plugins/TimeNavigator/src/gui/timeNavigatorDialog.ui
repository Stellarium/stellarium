     <!-- Tab 2: Specific Time                                            -->
     <!-- ═══════════════════════════════════════════════════════════════ -->
     <widget class="QWidget" name="tabSpecificTime">
      <attribute name="title"><string>Specific Time</string></attribute>
      <layout class="QVBoxLayout" name="vboxSpecificTime">

       <!-- Selected object: RTS -->
       <item>
        <widget class="QGroupBox" name="groupRTS">
         <property name="title"><string>Selected object</string></property>
         <layout class="QGridLayout" name="gridRTS">

          <item row="0" column="0" colspan="3">
           <widget class="QLabel" name="labelSelectedObject">
            <property name="text"><string>No object selected</string></property>
            <property name="alignment"><set>Qt::AlignCenter</set></property>
           </widget>
          </item>

          <item row="1" column="0"><widget class="QLabel" name="labelRTSPrev"><property name="text"><string>Previous</string></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
          <item row="1" column="1"><widget class="QLabel" name="labelRTSToday"><property name="text"><string>Today</string></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
          <item row="1" column="2"><widget class="QLabel" name="labelRTSNext"><property name="text"><string>Next</string></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>

          <item row="2" column="0"><widget class="QPushButton" name="btnPreviousRising"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Rising</string></property><property name="toolTip"><string>Previous rising of the selected object</string></property></widget></item>
          <item row="2" column="1"><widget class="QPushButton" name="btnTodayRising"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Rising</string></property><property name="toolTip"><string>Today's rising of the selected object</string></property></widget></item>
          <item row="2" column="2"><widget class="QPushButton" name="btnNextRising"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Rising</string></property><property name="toolTip"><string>Next rising of the selected object</string></property></widget></item>

          <item row="3" column="0"><widget class="QPushButton" name="btnPreviousTransit"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Transit</string></property><property name="toolTip"><string>Previous transit of the selected object</string></property></widget></item>
          <item row="3" column="1"><widget class="QPushButton" name="btnTodayTransit"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Transit</string></property><property name="toolTip"><string>Today's transit of the selected object</string></property></widget></item>
          <item row="3" column="2"><widget class="QPushButton" name="btnNextTransit"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Transit</string></property><property name="toolTip"><string>Next transit of the selected object</string></property></widget></item>

          <item row="4" column="0"><widget class="QPushButton" name="btnPreviousSetting"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Setting</string></property><property name="toolTip"><string>Previous setting of the selected object</string></property></widget></item>
          <item row="4" column="1"><widget class="QPushButton" name="btnTodaySetting"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Setting</string></property><property name="toolTip"><string>Today's setting of the selected object</string></property></widget></item>
          <item row="4" column="2"><widget class="QPushButton" name="btnNextSetting"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Setting</string></property><property name="toolTip"><string>Next setting of the selected object</string></property></widget></item>

         </layout>
        </widget>
       </item>

       <!-- Twilight -->
       <item>
        <widget class="QGroupBox" name="groupTwilight">
         <property name="title"><string>Twilight</string></property>
         <layout class="QGridLayout" name="gridTwilight">

          <item row="0" column="0" colspan="3">
           <layout class="QHBoxLayout" name="hboxTwilightAlt">
            <item><widget class="QLabel" name="labelTwilightAlt"><property name="text"><string>Solar altitude:</string></property></widget></item>
            <item>
             <widget class="QDoubleSpinBox" name="spinBoxTwilightAltitude">
              <property name="toolTip"><string>Solar altitude used for twilight calculations (synced with View → Sky)</string></property>
              <property name="alignment"><set>Qt::AlignRight|Qt::AlignTrailing|Qt::AlignVCenter</set></property>
              <property name="suffix"><string notr="true">°</string></property>
              <property name="decimals"><number>2</number></property>
              <property name="minimum"><double>-20.000000000000000</double></property>
              <property name="maximum"><double>0.000000000000000</double></property>
              <property name="singleStep"><double>0.100000000000000</double></property>
             </widget>
            </item>
            <item>
             <spacer><property name="orientation"><enum>Qt::Horizontal</enum></property><property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property></spacer>
            </item>
           </layout>
          </item>

          <item row="1" column="0"><widget class="QLabel" name="labelTwilightPrev"><property name="text"><string>Previous</string></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
          <item row="1" column="1"><widget class="QLabel" name="labelTwilightToday"><property name="text"><string>Today</string></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
          <item row="1" column="2"><widget class="QLabel" name="labelTwilightNext"><property name="text"><string>Next</string></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>

          <item row="2" column="0"><widget class="QPushButton" name="btnPreviousMorningTwilight"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Morning</string></property><property name="toolTip"><string>Previous morning twilight</string></property></widget></item>
          <item row="2" column="1"><widget class="QPushButton" name="btnTodayMorningTwilight"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Morning</string></property><property name="toolTip"><string>Today's morning twilight</string></property></widget></item>
          <item row="2" column="2"><widget class="QPushButton" name="btnNextMorningTwilight"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Morning</string></property><property name="toolTip"><string>Next morning twilight</string></property></widget></item>

          <item row="3" column="0"><widget class="QPushButton" name="btnPreviousEveningTwilight"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Evening</string></property><property name="toolTip"><string>Previous evening twilight</string></property></widget></item>
          <item row="3" column="1"><widget class="QPushButton" name="btnTodayEveningTwilight"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Evening</string></property><property name="toolTip"><string>Today's evening twilight</string></property></widget></item>
          <item row="3" column="2"><widget class="QPushButton" name="btnNextEveningTwilight"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy></property><property name="text"><string>Evening</string></property><property name="toolTip"><string>Next evening twilight</string></property></widget></item>

