[
    {
        "name": "setEnabled",
        "category": "Observability - Core",
        "signature": "void setEnabled(bool enabled)",
        "description": "Enables or disables the Observability report display on the screen.",
        "parameters": [
            {
                "name": "enabled",
                "type": "bool",
                "description": "true to show the report, false to hide",
                "required": true
            }
        ],
        "returnType": "void",
        "type": "slot",
        "compatibility": {
            "qt5": true,
            "qt6": true,
            "minVersion": "0.12.0"
        },
        "example": "Observability.setEnabled(true);\nObservability.setEnabled(false);"
    },
    {
        "name": "flagEnabled",
        "category": "Observability - Properties",
        "signature": "bool flagEnabled",
        "description": "Property that controls whether the observability report is displayed. Read via core.getStelProperty() or write via Observability.setEnabled().",
        "parameters": [],
        "returnType": "bool",
        "type": "property",
        "compatibility": {
            "qt5": true,
            "qt6": true,
            "minVersion": "0.12.0"
        },
        "example": "var enabled = core.getStelProperty('Observability.flagEnabled');\nObservability.setEnabled(!enabled);"
    },
    {
        "name": "setFontColor",
