     <!-- ═══════════════════════════════════════════════════════════════ -->
     <!-- Tab 1: Time Steps                                               -->
     <!-- ═══════════════════════════════════════════════════════════════ -->
     <widget class="QWidget" name="tabTimeSteps">
      <attribute name="title"><string>Time Steps</string></attribute>
      <layout class="QVBoxLayout" name="vboxTimeSteps">

       <!-- Header label -->
