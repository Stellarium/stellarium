    {
        "name": "setTwilightAltitude",
        "category": "Observability - Configuration",
        "signature": "void setTwilightAltitude(int altitude)",
        "description": "Sets the angular altitude of the Sun below the horizon that defines twilight (negative values).",
        "parameters": [
            {
                "name": "altitude",
                "type": "int",
                "description": "Twilight altitude in degrees (e.g., -12 for nautical twilight)",
                "required": true
            }
        ],
        "returnType": "void",
        "type": "slot",
        "compatibility": {
            "qt5": true,
            "qt6": true,
            "minVersion": "0.12.0"
        },
        "example": "Observability.setTwilightAltitude(-18);  // Astronomical twilight"
    },
    {
        "name": "setHorizonAltitude",
