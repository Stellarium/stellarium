         <layout class="QGridLayout" name="gridAtAltitude">

          <item row="0" column="0"><widget class="QLabel" name="labelAltPrev"><property name="text"><string>Previous</string></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
          <item row="0" column="1"><widget class="QLabel" name="labelAltToday"><property name="text"><string>Today</string></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
