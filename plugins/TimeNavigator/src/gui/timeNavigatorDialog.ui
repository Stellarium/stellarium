         <layout class="QGridLayout" name="gridLongCycles">
          <item row="0" column="0">
           <layout class="QHBoxLayout">
            <item><widget class="QToolButton" name="btnSubMetonicCycle"><property name="text"><string>&#9664;</string></property><property name="toolTip"><string>Subtract 1 Metonic cycle (235 synodic months ≈ 19 years)</string></property></widget></item>
            <item><widget class="QLabel"><property name="text"><string>Metonic cycle</string></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item>
